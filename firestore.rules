rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /players/{uid} {
      allow read, create, update: if request.auth != null && request.auth.uid == uid;
      allow delete: if false;
    }
    match /weeklyRankings/{weekId}/players/{uid} {
      allow read: if true;
      allow create, update: if request.auth != null
                            && request.auth.uid == uid
                            && request.resource.data.uid == uid
                            && request.resource.data.points is int
                            && request.resource.data.points >= 0;
      allow delete: if false;
    }
    match /dailyChallenge/{docId} { allow read: if true; allow write: if false; }
  }
}
