rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function isAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/players/$(request.auth.uid))
        && get(/databases/$(database)/documents/players/$(request.auth.uid)).data.isAdmin == true;
    }
    match /players/{uid} {
      allow read: if signedIn() && (request.auth.uid == uid || isAdmin());
      allow create: if signedIn() && request.auth.uid == uid
                    && (!('isAdmin' in request.resource.data) || request.resource.data.isAdmin == false);
      allow update: if isAdmin() || (signedIn() && request.auth.uid == uid
                    && request.resource.data.get('isAdmin', false) == resource.data.get('isAdmin', false));
      allow delete: if isAdmin();
    }
    match /weeklyRankings/{weekId}/players/{uid} {
      allow read: if true;
      allow create, update: if isAdmin() || (signedIn() && request.auth.uid == uid
                            && request.resource.data.uid == uid
                            && request.resource.data.points is int
                            && request.resource.data.points >= 0);
      allow delete: if isAdmin();
    }
    match /customQuestions/{questionId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }
    match /activities/{activityId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }
    match /blockedUsers/{uid} {
      allow read: if signedIn() && (request.auth.uid == uid || isAdmin());
      allow create, update, delete: if isAdmin();
    }
    match /dailyChallenge/{docId} { allow read: if true; allow write: if isAdmin(); }
  }
}
